# Copy this file to inventory.ini and fill in your server details.
# inventory.ini is gitignored to keep IPs and key paths out of version control.

[production]
tech ansible_host=<server-ip> ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa

[staging]
dev ansible_host=<server-ip> ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa
